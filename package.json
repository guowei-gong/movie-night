{
  "name": "movie-night",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && node scripts/generate-seo.mjs dist public/data",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "data:sync": "scripts/sync-data.sh",
    "data:validate": "node scripts/validate-data.mjs public/data"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "artplayer": "^5.2.5",
    "hls.js": "^1.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^3.2.7"
  }
}
